---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout
  title="Narrow Body Mode"
  subtitle="50% body width maintained when panels are hidden"
  date="2026-03-01"
  tags={["demo", "layout"]}
  showLeftPanel={false}
  showRightPanel={false}
  narrowBody={true}
>
  <h2>Narrow body mode</h2>
  <p>
    This page uses <code>showLeftPanel={false}</code>, <code>showRightPanel={false}</code>,
    and <code>narrowBody={true}</code>. The body stays at 50% width and is centered in the
    container — the same column width as when panels are visible, but with whitespace on each side
    instead of panel content.
  </p>
  <p>
    This is useful for focused reading views, long-form essays, or any content where you want
    a consistent narrow measure regardless of whether side panels are present.
  </p>
