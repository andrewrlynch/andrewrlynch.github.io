---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import pubs from '../data/pubs.json';

const posts = (await getCollection('posts', ({ data }) => data.published !== false))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const projects = (await getCollection('projects', ({ data }) => data.published !== false))
  .slice(0, 3);

const sortedPubs = [...pubs].sort((a, b) => {
  const pa = a.issued['date-parts'][0];
  const pb = b.issued['date-parts'][0];
  const da = `${pa[0]}-${String(pa[1] ?? 1).padStart(2, '0')}-${String(pa[2] ?? 1).padStart(2, '0')}`;
  const db = `${pb[0]}-${String(pb[1] ?? 1).padStart(2, '0')}-${String(pb[2] ?? 1).padStart(2, '0')}`;
  return db.localeCompare(da);
}).slice(0, 3);
---

<BaseLayout title="Andrew Lynch">
  <div class="section-vertical-header-container">
    <div class="section-vertical-header">about</div>
    <div class="section-vertical-header-body">
      I do cancer genomics and study tumor evolution, genomic instability, and phenotype plasticity to advance precision medicine.
    </div>
  </div>

  <div class="section-vertical-header-container">
    <div class="section-vertical-header">now</div>
    <div class="section-vertical-header-body">
      I'm a postdoc in the Cancer Genomics and Evolution Laboratory at the University of Texas MD Anderson Cancer Center. I hold an NRSA fellowship from the National Cancer Institute and a TRIUMPH fellowship from the Cancer Prevention and Research Institute of Texas.
    </div>
  </div>

  <div class="section-vertical-header-container">
    <div class="section-vertical-header">then</div>
    <div class="section-vertical-header-body">
      I earned my Ph.D. in Cell and Molecular Pathology at the University of Wisconsin - Madison where I developed novel methods to quantify chromosomal instability in tumors. Before that, I earned my B.Sc. in Biochemistry and Molecular Biology at the University of Wisconsin - Eau Claire.
    </div>
  </div>

  <div class="section-vertical-header-container">
    <div class="section-vertical-header">posts</div>
    <div class="section-vertical-header-body">
      <p>
        {posts.map((post, i) => (
          <>
            <a href={`/posts/${post.slug}`}><small>{post.data.title}</small></a>
            <small> - {post.data.date.toLocaleDateString('en-US', { day: '2-digit', month: 'short', year: 'numeric' })}</small>
            {i < posts.length - 1 && ' · '}
          </>
        ))}
        {' '}<a href="/posts"><small>[ + ]</small></a>
      </p>
    </div>
  </div>

  <div class="section-vertical-header-container">
    <div class="section-vertical-header">papers</div>
    <div class="section-vertical-header-body">
      <p>
        {sortedPubs.map((pub, i) => {
          const year = pub.issued['date-parts'][0][0];
          const firstAuthorLastName = pub.author[0]?.family ?? '';
          return (
            <>
              <a href={pub.URL}><small>{pub.title}</small></a>
              <small> - {firstAuthorLastName} et al. <em>{pub['container-title']}.</em> {year}.</small>
              {i < sortedPubs.length - 1 && ' · '}
            </>
          );
        })}
        {' '}<a href="/papers"><small>[ + ]</small></a>
      </p>
    </div>
  </div>

  <div class="section-vertical-header-container">
    <div class="section-vertical-header">projects</div>
    <div class="section-vertical-header-body">
      <p>
        {projects.map((project, i) => (
          <>
            <a href={`/projects/${project.slug}`}><small>{project.data.title}</small></a>: <small>{project.data.description}</small>
            {i < projects.length - 1 && ' · '}
          </>
        ))}
        {' '}<a href="/projects"><small>[ + ]</small></a>
      </p>
    </div>
  </div>
</BaseLayout>
