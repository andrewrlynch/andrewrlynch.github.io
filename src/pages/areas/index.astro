---
import CatalogueLayout from '../../layouts/CatalogueLayout.astro';
import { getCollection } from 'astro:content';

const areas = (await getCollection('areas'))
  .filter((area) => area.data.published !== false)
  .sort((a, b) => a.data.title.localeCompare(b.data.title));
---

<CatalogueLayout title="Areas">
  {areas.map((area) => (
    <div class="catalogue-card">
      <a href={`/areas/${area.slug}`} class="card-title">{area.data.title}</a>
      {area.data.description && (
        <p class="card-desc">{area.data.description}</p>
      )}
    </div>
  ))}
</CatalogueLayout>

<style>
  .catalogue-card {
    break-inside: avoid;
    margin-bottom: 20px;
    padding: 16px;
    border-radius: 4px;
    background: rgb(248, 246, 243);
  }

  .card-title {
    display: block;
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 1.05rem;
    font-weight: 500;
    color: #202020;
    text-decoration: none;
    line-height: 1.35;
    margin-bottom: 4px;
  }

  .card-title:hover {
    color: #f87f28;
  }

  .card-desc {
    font-size: 0.8rem;
    color: rgb(102, 97, 93);
    line-height: 1.4;
    margin: 0;
    font-weight: 300;
  }
</style>
