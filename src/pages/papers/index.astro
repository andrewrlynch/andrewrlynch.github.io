---
import CatalogueLayout from '../../layouts/CatalogueLayout.astro';
import { getCollection } from 'astro:content';

// Load papers from content collection (published !== false)
const collectionPapers = await getCollection('papers', ({ data }) => data.published !== false);

// Sort papers by date/year descending
const sortedPapers = [...collectionPapers].sort((a, b) => {
  const da = a.data.date ?? (a.data.year ? new Date(a.data.year, 0, 1) : new Date(0));
  const db = b.data.date ?? (b.data.year ? new Date(b.data.year, 0, 1) : new Date(0));
  return db.getTime() - da.getTime();
});

function formatDate(d: Date): string {
  return d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
}

function isSelfAuthor(name: string): boolean {
  const hasLynch = /lynch/i.test(name);
  const hasAndrew = /andrew/i.test(name) || /\bA\.?\s*R?\.?\s*Lynch/i.test(name) || /Lynch,?\s+A/i.test(name);
  return hasLynch && hasAndrew;
}
---

<CatalogueLayout title="Papers" maxCols={1} minCols={1} defaultView={"feed"} displayToggle={false}>
  {sortedPapers.map((paper) => {
    const { title, authors, journal, date, year, thumbnail } = paper.data;
    const displayDate = date ? formatDate(date) : (year ? String(year) : '');
    return (
      <div class="catalogue-card">
        {thumbnail && (
          <img
            src={thumbnail}
            alt=""
            role="presentation"
            class="card-thumbnail"
          />
        )}
        <div class="card-meta">
          {journal && <span class="card-journal">{journal}</span>}
          {displayDate && <time class="card-date">{displayDate}</time>}
        </div>
        <a href={`/papers/${paper.slug}`} class="card-title">
          {title}
        </a>
        {authors && authors.length > 0 && (
          <p class="card-authors">
            {authors.map((author, i) => {
              const isMe = isSelfAuthor(author);
              const sep = i === 0 ? '' : ', ';
              return (
                <Fragment>
                  {sep}{isMe ? <u>{author}</u> : author}
                </Fragment>
              );
            })}
          </p>
        )}
      </div>
    );
  })}
</CatalogueLayout>

<style>
  .catalogue-card {
    break-inside: avoid;
    margin-bottom: 20px;
    padding: 16px;
    border-radius: 4px;
    background: rgb(248, 246, 243);
  }

  .card-thumbnail {
    width: 100%;
    height: 160px;
    object-fit: cover;
    border-radius: 4px;
    display: block;
    margin-bottom: 12px;
  }

  .card-meta {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin-bottom: 6px;
    flex-wrap: wrap;
  }

  .card-journal {
    font-family: Menlo, 'Courier New', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.05em;
    color: rgb(102, 97, 93);
    font-style: italic;
  }

  .card-date {
    font-family: Menlo, 'Courier New', monospace;
    font-size: 0.65rem;
    color: rgb(152, 147, 143);
    letter-spacing: 0.03em;
  }

  .card-title {
    display: block;
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 1.05rem;
    font-weight: 500;
    color: #202020;
    text-decoration: none;
    line-height: 1.35;
    margin-bottom: 6px;
  }

  .card-title:hover {
    color: #f87f28;
  }

  .card-authors {
    font-size: 0.75rem;
    color: rgb(102, 97, 93);
    line-height: 1.4;
    margin: 0;
    font-weight: 300;
  }

  .card-authors u {
    text-decoration: underline;
    color: #202020;
  }
</style>
