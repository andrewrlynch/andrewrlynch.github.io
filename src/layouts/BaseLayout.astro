---
import '../styles/main.scss';

interface Props {
  title?: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en-US">
<head>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600;1,700&display=swap" rel="stylesheet">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta charset="utf-8">
  <title>{title && title !== 'Andrew Lynch' ? `Andrew Lynch → ${title}` : 'Andrew Lynch'}</title>
</head>
<body>
  <div class="site-container">
    <div class="site-header-container grid-width-full">
      <a href="/"><b>Andrew Lynch</b></a>{title && title !== 'Andrew Lynch' && <Fragment> &rarr; {title}</Fragment>}
    </div>
    <div class="site-body-container grid-width-full">
      <slot />
    </div>
    <div class="site-footer-container grid-width-full">
      <div class="site-footer-content">
        <a href="/about">colophon</a> ⸱ <a href="https://bsky.app/profile/arlynch.bsky.social">bluesky</a> ⸱ <a href="https://github.com/andrewrlynch">github</a> ⸱ <a href="https://www.linkedin.com/in/andrewrlynch">linkedin</a> ⸱ <a href="/cv">cv</a> ⸱ <a href="https://orcid.org/0000-0002-0238-682X">orcid</a>
      </div>
    </div>
  </div>
</body>
</html>
